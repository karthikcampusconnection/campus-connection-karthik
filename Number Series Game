import java.util.*;
public class NumberSeriesGame {
    public static void main(String[] args) {
        Scanner sc = new Scanner(System.in);
        int[] series = {2, 4, 6, 8, 10};
        System.out.println("Guess the next number in series:");
        for(int n : series) {
            System.out.print(n + " ");
        }
        int answer = sc.nextInt();
        if(answer == 12) {
            System.out.println("Correct! 🎉");
        } else {
            System.out.println("Wrong! Correct answer is 12");
        }
    }
}
